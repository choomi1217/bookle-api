# Bookle 환경변수 템플릿
# 실제 값을 채워 .env 파일로 복사 (.env 는 커밋 금지)
# 로컬 실행 시: `env $(cat .env | xargs) ./gradlew bootRun`
# EC2 운영: /etc/bookle.env 또는 systemd EnvironmentFile 로 주입

# --- Database (RDS PostgreSQL) ---
DB_HOST=
DB_PORT=5432
DB_NAME=bookle
DB_USER=
DB_PASSWORD=

# --- Claude API ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Bookle API Gateway Key (모바일 앱 → 서버) ---
WORDBOOK_API_KEY=

# --- 선택 ---
SERVER_PORT=8080
WORDBOOK_CORS_ORIGINS=*
